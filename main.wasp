//#region Credits
query getCreditsBalance {
  fn: import { getCreditsBalance } from "@src/credits/creditOperations",
  entities: [User]
}

query getCreditTransactions {
  fn: import { getCreditTransactions } from "@src/credits/creditOperations",
  entities: [CreditTransaction]
}

job resetMonthlyCredits {
  executor: PgBoss,
  perform: {
    fn: import { resetMonthlyCredits } from "@src/credits/creditResetJob"
  },
  schedule: {
    cron: "0 0 * * *"
  },
  entities: [User, CreditTransaction]
}
//#endregion

