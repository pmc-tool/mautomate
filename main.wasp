  entities: [StoryProject, StoryScene, UserExtension, Setting, User, CreditTransaction]
}

action generateNarration {
  fn: import { generateNarration } from "@src/extensions/long-story-video/generationOperations",
  entities: [StoryProject, StoryScene, UserExtension, Setting, User, CreditTransaction]
}

action stitchStoryVideo {
  fn: import { stitchStoryVideo } from "@src/extensions/long-story-video/generationOperations",
  entities: [StoryProject, StoryScene, UserExtension, Setting, User, CreditTransaction]
}

action checkStoryStatus {
  fn: import { checkStoryStatus } from "@src/extensions/long-story-video/generationOperations",
  entities: [StoryProject, StoryScene, UserExtension, Setting]
}

// Job: Poll Novita for processing story scenes
job storyStatusCheck {
  executor: PgBoss,
  perform: {
    fn: import { storyStatusCheck } from "@src/extensions/long-story-video/storyCheckJob"
  },
  schedule: {
    cron: "* * * * *"
  },
  entities: [StoryProject, StoryScene, Setting, User, CreditTransaction]
}

//#endregion

// ---------------------------------------------------------------------------
//#region Affiliate System
// ---------------------------------------------------------------------------

// Routes & Pages
route AffiliateDashboardRoute { path: "/affiliate", to: AffiliateDashboardPage }
page AffiliateDashboardPage { authRequired: true, component: import AffiliateDashboardPage from "@src/affiliate/AffiliateDashboardPage" }

route AffiliateLinksRoute { path: "/affiliate/links", to: AffiliateLinksPage }
page AffiliateLinksPage { authRequired: true, component: import AffiliateLinksPage from "@src/affiliate/AffiliateLinksPage" }

route AffiliateEarningsRoute { path: "/affiliate/earnings", to: AffiliateEarningsPage }
page AffiliateEarningsPage { authRequired: true, component: import AffiliateEarningsPage from "@src/affiliate/AffiliateEarningsPage" }

route AffiliateWithdrawRoute { path: "/affiliate/withdraw", to: AffiliateWithdrawPage }
page AffiliateWithdrawPage { authRequired: true, component: import AffiliateWithdrawPage from "@src/affiliate/AffiliateWithdrawPage" }

route AdminAffiliateRoute { path: "/admin/affiliate", to: AdminAffiliatePage }
page AdminAffiliatePage { authRequired: true, component: import AdminAffiliatePage from "@src/admin/dashboards/affiliate/AdminAffiliatePage" }

route AdminAffiliateWithdrawalsRoute { path: "/admin/affiliate/withdrawals", to: AdminAffiliateWithdrawalsPage }
page AdminAffiliateWithdrawalsPage { authRequired: true, component: import AdminAffiliateWithdrawalsPage from "@src/admin/dashboards/affiliate/AdminAffiliateWithdrawalsPage" }

// Queries
query getAffiliateStats {
  fn: import { getAffiliateStats } from "@src/affiliate/operations",
  entities: [User, AffiliateLink, AffiliateClick, AffiliateConversion, AffiliateCommission, AffiliateWithdrawal]
}

query getAffiliateLink {
  fn: import { getAffiliateLink } from "@src/affiliate/operations",
  entities: [AffiliateLink, AffiliateClick, AffiliateConversion]
}

query getAffiliateCommissions {
  fn: import { getAffiliateCommissions } from "@src/affiliate/operations",
  entities: [AffiliateCommission, AffiliateLink]
}

query getAffiliateWithdrawals {
  fn: import { getAffiliateWithdrawals } from "@src/affiliate/operations",
  entities: [AffiliateWithdrawal]
}

query getAdminAffiliateOverview {
  fn: import { getAdminAffiliateOverview } from "@src/affiliate/adminOperations",
  entities: [User, AffiliateLink, AffiliateClick, AffiliateConversion, AffiliateCommission, AffiliateWithdrawal, Setting]
}

query getAdminWithdrawalRequests {
  fn: import { getAdminWithdrawalRequests } from "@src/affiliate/adminOperations",
  entities: [AffiliateWithdrawal, User]
}

// Actions
action createAffiliateLink {
  fn: import { createAffiliateLink } from "@src/affiliate/operations",
  entities: [AffiliateLink, User]
}

action updateAffiliateLink {
  fn: import { updateAffiliateLink } from "@src/affiliate/operations",
  entities: [AffiliateLink]
}

action claimReferral {
  fn: import { claimReferral } from "@src/affiliate/operations",
  entities: [User, AffiliateLink, AffiliateConversion]
}

action requestWithdrawal {
  fn: import { requestWithdrawal } from "@src/affiliate/operations",
  entities: [AffiliateWithdrawal, AffiliateCommission, User]
}

action processWithdrawal {
  fn: import { processWithdrawal } from "@src/affiliate/adminOperations",
  entities: [AffiliateWithdrawal, AffiliateCommission, Setting]
}

action updateAffiliateSettings {
  fn: import { updateAffiliateSettings } from "@src/affiliate/adminOperations",
  entities: [Setting]
}

action rejectWithdrawal {
  fn: import { rejectWithdrawal } from "@src/affiliate/adminOperations",
  entities: [AffiliateWithdrawal]
}

// Public API for click tracking
api affiliateTrackClick {
  fn: import { affiliateTrackClick } from "@src/affiliate/trackingApi",
  entities: [AffiliateLink, AffiliateClick],
  httpRoute: (GET, "/api/affiliate/track/:code"),
  auth: false
}

